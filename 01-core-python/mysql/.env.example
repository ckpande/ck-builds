# .env.example
# Copy to .env and fill in your MySQL credentials
# Never commit .env to Git

MYSQL_HOST=your_host
MYSQL_USER=your_username
MYSQL_PASS=your_password
MYSQL_DB=your_database
MYSQL_PORT=your_port

# Used by mysql_query_runner.py (loan_accounts table — fintech demo)
MYSQL_FINTECH_DB=your_fintech_database



